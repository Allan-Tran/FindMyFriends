rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function groupDoc(groupId) {
      let doc = get(/databases/$(database)/documents/groups/$(groupId));
      return doc != null ? doc.data : null;
    }

    function isAdmin(groupId) {
      let docData = groupDoc(groupId);
      return isSignedIn() && docData != null && docData.adminId == request.auth.uid;
    }

    function isMember(groupId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    // Public profile per user. Anyone signed in can resolve a uid to a username.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId
                       && request.resource.data.keys().hasOnly([
                            'email','username','usernameLower','createdAt','fcmToken','emailVerified'
                          ]);
      allow update: if isSignedIn()
                    && request.auth.uid == userId
                    && resource != null
                    && !request.resource.data.diff(resource.data)
                        .affectedKeys().hasAny(['username', 'usernameLower', 'createdAt']);
      allow delete: if false;
    }

    // Username -> uid reservation, used to enforce uniqueness during signup.
    match /usernames/{usernameLower} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Invite-code -> groupId lookup.
    match /inviteCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                       && request.resource.data.keys().hasOnly(['groupId'])
                       && request.resource.data.groupId is string;
      allow update: if false;
      allow delete: if isAdmin(resource.data.groupId);
    }

    // Direct messages
    match /dms/{dmId} {
      function isDMParticipant() {
        return resource != null
            && (request.auth.uid == resource.data.senderUid
                || request.auth.uid == resource.data.recipientUid);
      }
      function isDMParticipantCreate() {
        let dmRef = /databases/$(database)/documents/dms/$(dmId);
        return exists(dmRef)
            && (request.auth.uid == get(dmRef).data.senderUid
                || request.auth.uid == get(dmRef).data.recipientUid);
      }

      allow read: if isSignedIn() && isDMParticipant();
      allow create: if isSignedIn() && request.resource.data.senderUid == request.auth.uid;
      allow update, delete: if false;

      match /relay/{messageId} {
        allow read: if isSignedIn() && isDMParticipantCreate();
        allow create: if isSignedIn()
                         && request.resource.data.senderUid == request.auth.uid
                         && isDMParticipantCreate();
        allow update: if false;
        allow delete: if false;
      }
    }

    match /groups/{groupId} {
      allow read: if isSignedIn() && resource != null && request.auth.uid in resource.data.memberIds;
      allow create: if isSignedIn()
                       && request.resource.data.adminId == request.auth.uid
                       && request.resource.data.memberIds is list
                       && request.resource.data.memberIds.hasOnly([request.auth.uid]);
                       
      allow update: if isAdmin(groupId)
                    ||
                    (isSignedIn()
                        && resource != null
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
                        && request.auth.uid in request.resource.data.memberIds
                        && request.resource.data.memberIds.hasAll(resource.data.memberIds));
      allow delete: if isAdmin(groupId);

      match /members/{userId} {
        allow read: if isMember(groupId);
        allow create: if isSignedIn() &&
                         (request.auth.uid == userId || isAdmin(groupId)) &&
                         request.resource.data.role in ['member','admin'];
        allow update: if isAdmin(groupId);
        allow delete: if isAdmin(groupId) || request.auth.uid == userId;
      }

      match /relay/{messageId} {
        allow read: if isMember(groupId);
        allow create: if isMember(groupId)
                         && request.resource.data.senderUid == request.auth.uid
                         && request.resource.data.expiresAt > request.time;
        allow update: if false;
        allow delete: if isMember(groupId);
      }

      match /pins/{pinId} {
        allow read: if isMember(groupId);
        allow create: if isMember(groupId)
                         && request.resource.data.uid == request.auth.uid;
        allow update: if false;
        allow delete: if isMember(groupId)
                         && resource != null
                         && (resource.data.uid == request.auth.uid || isAdmin(groupId));
      }

      match /reports/{reportId} {
        allow read: if isAdmin(groupId);
        allow create: if isMember(groupId)
                         && request.resource.data.reporterUid == request.auth.uid
                         && request.resource.data.status == 'pending';
        allow update: if isAdmin(groupId)
                         && resource != null
                         && request.resource.data.diff(resource.data)
                              .affectedKeys().hasOnly(['status']);
        allow delete: if false;
      }
    }
  }
}
